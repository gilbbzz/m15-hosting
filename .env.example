# Salin file ini menjadi .env untuk development lokal.
# Di Railway, variabel MYSQL* ini otomatis disediakan saat Anda
# menambahkan plugin MySQL dan tidak perlu diisi manual.

PORT=3000

# --- Untuk development lokal saja ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=daily_inspiration

# --- Railway akan otomatis mengisi variabel berikut, JANGAN diisi manual di Railway ---
# MYSQL_URL=
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
